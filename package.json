{
  "name": "notion-oncaller",
  "version": "1.0.0",
  "description": "Slack-integrated on-call management tool backed by Notion",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "gcp-build": "",
    "start": "npx functions-framework --target=app --source=dist/",
    "dev": "tsc -w & npx functions-framework --target=app --source=dist/",
    "test": "jest",
    "test:watch": "jest --watch",
    "deploy": "bash deploy/deploy.sh",
    "lint": "eslint src/"
  },
  "keywords": [
    "notion",
    "slack",
    "oncall",
    "gcp",
    "cloud-function"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@google-cloud/functions-framework": "^5.0.2",
    "@notionhq/client": "^5.19.0",
    "@slack/bolt": "^4.7.0",
    "@slack/web-api": "^7.15.1",
    "dayjs": "^1.11.20"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^25.6.0",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.9",
    "typescript": "^6.0.3"
  }
}
